# We need matrix A columns to equal matrix B rows for multiplication.
# If this is not true, the product does not exist.


def multiplication_matrix(matrix_A, matrix_B):
    # Create a new list that will hold the result matrix.
    product_matrix = []

    # rows_A is how many rows are in A.
    # cols_A is how many columns are in A.
    # cols_B is how many columns are in B.
    rows_A = len(matrix_A)
    cols_A = len(matrix_A[0])
    cols_B = len(matrix_B[0])

    # For each row in A, we will build one row in the answer.
    for i in range(rows_A):
        r = []

        # For each column in B, compute one entry in the answer.
        for j in range(cols_B):
            cell_sum = 0

            # Multiply matching entries from A's row and B's column.
            # Then add them together to get the value for one cell.
            for k in range(cols_A):
                cell_sum += matrix_A[i][k] * matrix_B[k][j]

            # Save the computed value for this row and column.
            r.append(cell_sum)

        # Add the completed row to the product matrix.
        product_matrix.append(r)

    return product_matrix
            

